          "confidence": "high",
          "horizon": "days"
        },
        {
          "ticker": "CCL",
          "rationale": "Cruise operator with high bunker fuel exposure and discretionary travel demand; lower oil + reduced geopolitical anxiety drives bookings and margin both.",
          "confidence": "medium",
          "horizon": "weeks"
        },
        {
          "ticker": "LUV",
          "rationale": "Domestic carrier with the highest fuel-cost-as-percent-of-opex among US majors and limited hedging in recent quarters; pure beta to crude decline.",
          "confidence": "high",
          "horizon": "days"
        },
        {
          "ticker": "DOW",
          "rationale": "Naphtha/ethane feedstock costs fall with crude; commodity chemicals margin expands on lower input costs without immediate demand offset.",
          "confidence": "medium",
          "horizon": "weeks"
        }
      ],
      "losers": [
