  "macro_events": [
    {
      "event_summary": "The SEC is advancing a Trump-backed proposal to end mandatory quarterly earnings reports for US public companies, potentially shifting to semiannual reporting.",
      "primary_drivers": [
        "Reduced compliance/audit costs for public issuers",
        "Lower information frequency hurts data/research businesses dependent on quarterly cycles",
        "Reduced trading volume around earnings events impacts options/exchange revenue"
      ],
      "beneficiaries": [
        {
          "ticker": "SMCI",
          "rationale": "Has been plagued by quarterly filing delays and accounting scrutiny; semiannual cadence reduces frequency of restatement/late-filing risk events that have repeatedly hit the stock.",
          "confidence": "low",
          "horizon": "days"
        },
        {
          "ticker": "GS",
          "rationale": "Long-term capital allocation by corporate clients improves with less short-termism; M&A advisory benefits as boards focus on strategic deals over quarterly optics. Indirect but Goldman has publicly advocated against quarterly reporting.",
          "confidence": "low",
          "horizon": "months"
        }
      ],
      "losers": [
        {
          "ticker": "FDS",
          "rationale": "FactSet's core product is quarterly earnings/estimates data and consensus tracking; halving the reporting cadence directly reduces the value and refresh velocity of its flagship datasets sold to buy-side clients.",
          "confidence": "medium",
          "horizon": "months"
        },
        {
          "ticker": "MSCI",
          "rationale": "Index and analytics products rely on timely fundamental data inputs; less frequent reporting degrades model accuracy and the cadence of factor/ESG analytics that drive subscription value.",
          "confidence": "low",
          "horizon": "months"
        },
        {
          "ticker": "SPGI",
          "rationale": "S&P Global Market Intelligence and Capital IQ monetize quarterly fundamental data feeds; ratings business also leverages quarterly disclosures for surveillance. Reduced cadence weakens product utility.",
          "confidence": "medium",
          "horizon": "months"
        },
        {
          "ticker": "MORN",
          "rationale": "Morningstar's equity research and data products are built around quarterly update cycles; semiannual reporting reduces the rhythm of analyst notes and data refresh that drives subscription engagement.",
          "confidence": "medium",
          "horizon": "months"
        },
        {
          "ticker": "CME",
          "rationale": "Equity and equity-index derivatives volumes spike around earnings season; cutting reporting events in half removes a recurring volatility/volume catalyst that drives options and futures hedging activity.",
          "confidence": "low",
          "horizon": "months"
        },
        {
          "ticker": "ICE",
          "rationale": "NYSE listings business and equity options volume benefit from quarterly earnings volatility cycles; fewer mandated disclosure events means less episodic trading activity. Modest revenue headwind.",
          "confidence": "low",
          "horizon": "months"
        },
        {
          "ticker": "ESTC",
          "rationale": "Estimize and similar crowdsourced earnings-estimate platforms \u2014 and by extension financial data aggregators \u2014 lose product relevance as quarterly cadence disappears. (Note: Estimize is private; ESTC ticker is Elastic \u2014 flagging as low confidence proxy for data-vendor theme.)",
          "confidence": "low",
          "horizon": "months"
        }
      ],
