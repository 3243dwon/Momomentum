# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real secrets.

# Anthropic API key for the 3-tier LLM pipeline.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Feishu custom bot incoming webhook for alerts.
# Create a custom bot in a private Feishu group and paste the webhook URL here.
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/...

# Alpaca paper trading API keys for market data.
# Sign up at https://alpaca.markets/, generate keys from the paper-trading dashboard.
ALPACA_API_KEY=PK...
ALPACA_API_SECRET=...

# Optional: override default models (defaults are set in scanner/config.py)
# HAIKU_MODEL=claude-haiku-4-5-20251001
# SONNET_MODEL=claude-sonnet-4-6
# OPUS_MODEL=claude-opus-4-7
